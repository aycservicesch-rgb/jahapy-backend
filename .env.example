# Entorno. En produccion poner NODE_ENV=production: el errorHandler oculta
# stack traces y detalles internos (responde mensaje generico en errores 500).
# En Render, setear NODE_ENV=production en las env del servicio.
NODE_ENV=development

# Puerto del servidor. En Render NO hace falta setearlo: la plataforma lo inyecta.
# Local: no usar 5173 ni 4173 (los usa el frontend en preview).
PORT=4000

# Secreto para firmar los JWT. Cambialo por una cadena larga y aleatoria.
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio
JWT_EXPIRES_IN=7d

# --- Base de datos (PostgreSQL) ---
# Render: usar la Internal Database URL del Postgres creado.
DATABASE_URL="postgresql://user:pass@host:5432/db?schema=public"

# --- CORS ---
# Origenes permitidos para Express y Socket.IO (lista separada por comas).
# Si no se setea, se usan los defaults: http://localhost:5173, http://localhost:4173,
# https://jocular-cat-10b938.netlify.app
CORS_ORIGIN=http://localhost:5173,http://localhost:4173,https://jocular-cat-10b938.netlify.app
