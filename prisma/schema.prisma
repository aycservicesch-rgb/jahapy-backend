// Prisma schema - Jahapy backend
//
// DB: PostgreSQL. DATABASE_URL apunta al Postgres (Render en produccion).
// En deploy el schema se sincroniza con `prisma db push` (sin archivos de
// migracion por proveedor). Ver README ("Desplegar en Render").

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NOTA: `role` se guarda como String y se valida en la app (ver authController:
// VALID_ROLES). Valores: PASSENGER | DRIVER | COURIER | ADMIN.
// En Postgres se podria convertir a un enum nativo, pero no es necesario.

model User {
  id           String   @id @default(cuid())
  fullName     String
  email        String   @unique
  phone        String?  @unique
  passwordHash String
  role         String   @default("PASSENGER")
  city         String?
  rating       Float?   @default(5.0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relaciones con viajes
  ridesAsPassenger Ride[] @relation("PassengerRides")
  ridesAsDriver    Ride[] @relation("DriverRides")

  // Relaciones con pedidos de comida (delivery)
  ordersAsCustomer FoodOrder[] @relation("CustomerOrders")
  ordersAsCourier  FoodOrder[] @relation("CourierOrders")

  // Perfiles de verificacion (conductor / comercio)
  driverProfile   DriverProfile?
  businessProfiles BusinessProfile[] @relation("BusinessOwner")

  // Viajes programados (reservas)
  scheduledRides  ScheduledRide[] @relation("PassengerScheduled")

  // Notas del CRM (escritas por el admin sobre este usuario)
  notes           UserNote[] @relation("UserNotes")
}

// UserNote: nota del CRM que el admin escribe sobre un cliente/usuario.
model UserNote {
  id        String   @id @default(cuid())
  userId    String   // usuario sobre el que es la nota
  authorId  String   // admin que la escribió
  text      String
  createdAt DateTime @default(now())

  user User @relation("UserNotes", fields: [userId], references: [id])

  @@index([userId])
}

// DriverProfile: datos del vehiculo + estado de verificacion del conductor.
// La aprobacion vive en la BD (no solo en el dispositivo) y se exige del lado
// servidor: el socket `driver:online` y `ride:accept` la consultan.
//   status: pending | approved | rejected (validado en la app: PROFILE_STATUSES)
//   docs: String JSON con flags de documentos cargados, ej {"license":true,"id":true}
//   commissionDue: comision adeudada (en guaranies) por viajes en efectivo.
model DriverProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  status        String   @default("pending")
  vehicleType   String?
  brand         String?
  model         String?
  year          Int?
  plate         String?
  docs          String?  // JSON: { license, id, insurance, ... }
  commissionDue Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([status])
}

// BusinessProfile: comercio (restaurante) con estado de verificacion.
// `business:online` exige status === 'approved' del lado servidor.
//   status: pending | approved | rejected
//   menu: String JSON opcional (para otra fase).
model BusinessProfile {
  id        String   @id @default(cuid())
  ownerId   String
  name      String
  category  String?
  status    String   @default("pending")
  address   String?
  phone     String?
  menu      String?  // JSON opcional (fase posterior)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner User @relation("BusinessOwner", fields: [ownerId], references: [id])

  @@index([ownerId])
  @@index([status])
}

// Ride: un viaje de transporte solicitado por un pasajero y tomado por un conductor.
// NOTA: `status` y `rideType` son String validados en la app
// (ver src/services/rideService.js: RIDE_STATUSES / transiciones).
//   status: REQUESTED | ACCEPTED | ARRIVING | ARRIVED | IN_PROGRESS | COMPLETED | CANCELLED
//   rideType: standard | moto | xl | ...
model Ride {
  id          String   @id @default(cuid())
  passengerId String
  driverId    String?
  status      String   @default("REQUESTED")
  rideType    String   @default("standard")

  originLat   Float
  originLng   Float
  originLabel String?
  destLat     Float
  destLng     Float
  destLabel   String?

  distanceKm  Float?
  durationMin Float?
  fare        Int? // en guaranies

  // Metodo de pago: "cash" | "card" | ... Solo "cash" genera comision al conductor.
  paymentMethod String @default("cash")

  cancelReason String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  acceptedAt  DateTime?
  completedAt DateTime?

  passenger User  @relation("PassengerRides", fields: [passengerId], references: [id])
  driver    User? @relation("DriverRides", fields: [driverId], references: [id])

  @@index([passengerId])
  @@index([driverId])
  @@index([status])
}

// FoodOrder: un pedido de delivery hecho por un CLIENTE a un COMERCIO y
// entregado por un REPARTIDOR. Espejo del patron de Ride para tiempo real.
// NOTA: `status` es String validado en la app
// (ver src/services/foodOrderService.js: ORDER_STATUSES / transiciones).
//   status: PLACED | CONFIRMED | PREPARING | READY | PICKED_UP | DELIVERING | DELIVERED | CANCELLED
//   items: String JSON -> [{ name, qty, price }]
//   businessId: por ahora un String libre (id del comercio). Sin tabla Business todavia.
model FoodOrder {
  id          String   @id @default(cuid())
  customerId  String
  businessId  String
  courierId   String?
  status      String   @default("PLACED")

  items       String // JSON: [{ name, qty, price }]
  subtotal    Int // en guaranies
  deliveryFee Int
  total       Int
  address     String
  notes       String?
  cancelReason String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  confirmedAt DateTime?
  readyAt     DateTime?
  deliveredAt DateTime?

  customer User  @relation("CustomerOrders", fields: [customerId], references: [id])
  courier  User? @relation("CourierOrders", fields: [courierId], references: [id])

  @@index([customerId])
  @@index([courierId])
  @@index([businessId])
  @@index([status])
}

// CommissionPayment: reporte de pago de comision hecho por un CONDUCTOR.
// El conductor transfiere su comision adeudada al alias de la plataforma y
// REPORTA el pago (queda 'pending'). Un ADMIN lo confirma (o la API de ueno lo
// verifica automaticamente) -> se descuenta de DriverProfile.commissionDue.
// Nunca el conductor resetea su propia deuda: eso cierra el hueco de seguridad.
//   status: pending | confirmed | rejected
//   method: ueno_alias | bancard | other
model CommissionPayment {
  id         String    @id @default(cuid())
  driverId   String    // User.id del conductor
  amount     Int       // guaranies reportados
  method     String    @default("ueno_alias")
  reference  String?   // nro de comprobante / referencia de la transferencia
  status     String    @default("pending")
  note       String?   // nota del admin (motivo de rechazo, etc.)
  autoVerified Boolean @default(false) // true si lo confirmo la API de ueno
  createdAt  DateTime  @default(now())
  reviewedAt DateTime?
  reviewedBy String?   // User.id del admin que confirmo/rechazo

  @@index([driverId])
  @@index([status])
}

// ScheduledRide: una RESERVA de viaje para un momento futuro. Un scheduler en
// el server despacha las que llegan a su hora (crea un Ride y avisa a los
// conductores cercanos + push al pasajero).
//   status: scheduled | dispatched | cancelled
model ScheduledRide {
  id           String   @id @default(cuid())
  passengerId  String
  rideType     String   @default("standard")

  originLat    Float
  originLng    Float
  originLabel  String?
  destLat      Float
  destLng      Float
  destLabel    String?

  distanceKm   Float?
  durationMin  Float?
  fare         Int?

  scheduledFor DateTime
  status       String   @default("scheduled")
  rideId       String?  // Ride creado al despachar
  createdAt    DateTime @default(now())
  dispatchedAt DateTime?

  passenger User @relation("PassengerScheduled", fields: [passengerId], references: [id])

  @@index([passengerId])
  @@index([status, scheduledFor])
}

// DriverDocument: imagen REAL de un documento del conductor (CI, licencia,
// selfie, cedula verde, fotos del vehiculo, etc.). Se guarda la imagen
// comprimida como data URL (base64) en la BD. Una fila por (driverId, kind).
//   kind: ci | licencia | selfie | antecedentes | cedulaVerde | rtv |
//         frente | atras | lateral | interior
model DriverDocument {
  id        String   @id @default(cuid())
  driverId  String   // User.id del conductor
  kind      String
  dataUrl   String   // imagen comprimida (data:image/jpeg;base64,...)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([driverId, kind])
  @@index([driverId])
}

